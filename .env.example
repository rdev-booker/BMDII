# ─── BMD Transportation — Environment Variables ───────────────────────────────
# Copy this file to .env.local for local development.
# Set these variables in: Netlify Dashboard → Site → Environment Variables

# ── Contact form (add when wiring up the quote form handler) ──────────────────
# RESEND_API_KEY=re_xxxxxxxxxxxx
# CONTACT_TO_EMAIL=dispatch@bmdtransportation.ca

# ── Site URL (used for OG/canonical tags) ─────────────────────────────────────
# NEXT_PUBLIC_SITE_URL=https://www.bmdtransportation.ca
